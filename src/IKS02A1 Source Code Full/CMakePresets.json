{
  "version": 3,
  "configurePresets": [
    {
      "name": "app",
      "displayName": "Application Build",
      "description": "Build configuration for NucleoMX_IKS02A1 application",
      "generator": "Unix Makefiles",
      "binaryDir": "${sourceDir}/build",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release"
      },
      "environment": {
        "CC": "arm-none-eabi-gcc",
        "CXX": "arm-none-eabi-g++",
        "AR": "arm-none-eabi-ar",
        "OBJCOPY": "arm-none-eabi-objcopy",
        "OBJDUMP": "arm-none-eabi-objdump",
        "SIZE": "arm-none-eabi-size"
      }
    }
  ],
  "buildPresets": [
    {
      "name": "app",
      "configurePreset": "app",
      "jobs": 4
    }
  ]
}
