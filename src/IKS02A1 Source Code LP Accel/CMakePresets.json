{
  "version": 3,
  "configurePresets": [
    {
      "name": "app",
      "displayName": "Application Build",
      "description": "Build configuration for NucleoMX_IKS02A1_LP_Accel application",
      "generator": "Unix Makefiles",
      "binaryDir": "${sourceDir}/build",
